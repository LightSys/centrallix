##NAME convert() function - Encodings

# generate a full set of valid bytes for single byte encodings, and a representative sample for multibyte.
# use to/from hex to convert to binary datatype
query DECLARE OBJECT data SCOPE APPLICATION; SELECT :data:utf8 = 'AaBbCc010203,!"ВЎВўВҘГҶГғгҒҒгҒӮгҒғгҒ„гҒ…гҒҶгҒҮгҒҲгҒүрҹЁҖрҹЁҒрҹЁӮрҹЁғрҹЁ„рҹЁ…'
# full hex set: ''
query SELECT :data:ascii	= convert('string', from_hex('0102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f202122232425262728292a2b2c2d2e2f303132333435363738393a3b3c3d3e3f404142434445464748494a4b4c4d4e4f505152535455565758595a5b5c5d5e5f606162636465666768696a6b6c6d6e6f707172737475767778797a7b7c7d7e7f'))
query SELECT :data:latin1	= convert('string', from_hex('202122232425262728292a2b2c2d2e2f303132333435363738393a3b3c3d3e3f404142434445464748494a4b4c4d4e4f505152535455565758595a5b5c5d5e5f606162636465666768696a6b6c6d6e6f707172737475767778797a7b7c7d7ea0a1a2a3a4a5a6a7a8a9aaabacadaeafb0b1b2b3b4b5b6b7b8b9babbbcbdbebf' + 'c0c1c2c3c4c5c6c7c8c9cacbcccdcecfd0d1d2d3d4d5d6d7d8d9dadbdcdddedfe0e1e2e3e4e5e6e7e8e9eaebecedeeeff0f1f2f3f4f5f6f7f8f9fafbfcfdfeff'))
query SELECT :data:cp1252	= convert('string', from_hex('0102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f202122232425262728292a2b2c2d2e2f303132333435363738393a3b3c3d3e3f404142434445464748494a4b4c4d4e4f505152535455565758595a5b5c5d5e5f606162636465666768696a6b6c6d6e6f707172737475767778797a7b7c7d7e7f' + '8082838485868788898a8b8c8e9192939495969798999a9b9c9e9fa0a1a2a3a4a5a6a7a8a9aaabacadaeafb0b1b2b3b4b5b6b7b8b9babbbcbdbebfc0c1c2c3c4c5c6c7c8c9cacbcccdcecfd0d1d2d3d4d5d6d7d8d9dadbdcdddedfe0e1e2e3e4e5e6e7e8e9eaebecedeeeff0f1f2f3f4f5f6f7f8f9fafbfcfdfeff'))
query SELECT :data:vanco	= convert('string', from_hex('c280c282c283c284c285c286c287c289c289c28ac28bc28cc28ec28ec291c292c293c294c295c296c297c298c299c29ac29bc29cc29ec29f')) + :data:ascii + "ВЎВўВЈВӨВҘВҰВ§ВЁВ©ВӘВ«В¬В®ВҜВ°ВұВІВіВҙВөВ¶В·ВёВ№ВәВ»ВјВҪВҫВҝГҖГҒГӮГғГ„Г…ГҶГҮГҲГүГҠГӢГҢГҚГҺГҸГҗГ‘Г’Г“Г”Г•Г–Г—ГҳГҷГҡГӣГңГқГһГҹГ ГЎГўГЈГӨГҘГҰГ§ГЁГ©ГӘГ«Г¬ГӯГ®ГҜГ°ГұГІГіГҙГөГ¶Г·ГёГ№ГәГ»ГјГҪГҫГҝ"

# Convert from ASCII
csv SELECT "ascii to ascii"	= convert('string', convert('ascii',		'ascii',	:data:ascii))
csv SELECT "ascii to latin1"	= convert('string', convert('AsCiI',		'latin1',	:data:ascii))
csv SELECT "ascii to cp1252"	= convert('string', convert('aScIi',		'cp1252',	:data:ascii))
csv SELECT "ascii to utf8"	= convert('string', convert('ASCII',		'utf8',		:data:ascii))

# Convert from Latin-1
csv SELECT "latin1 to ascii"	= convert('string', convert('latin1',		'ascii',	:data:latin1))
csv SELECT "latin1 to latin1"	= convert('string', convert('LATIN-1',		'latin1',	:data:latin1))
csv SELECT "latin1 to cp1252"	= convert('string', convert('ISO-8859-1',	'cp1252',	:data:latin1))
csv SELECT "latin1 to utf8"	= convert('string', convert('ISO/IEC 8859-1',	'utf8',		:data:latin1))
# test more names 
csv select "latin1 names test" = convert('string', convert('ISO 8859-1', 'EIC 8859-1', convert('EIC-8859-1', 'iso/iec 8859-1', 'Test')))

# Convert from UTF-8
csv SELECT "utf8 to ascii"	= convert('string', convert('utf8',		'ascii',	:data:utf8))
csv SELECT "utf8 to latin1"	= convert('string', convert('UTF-8',		'latin1',	:data:utf8))
csv SELECT "utf8 to cp1252"	= convert('string', convert('Unicode',		'cp1252',	:data:utf8))
csv SELECT "utf8 to utf8"	= convert('string', convert('uniCode',		'utf8',		:data:utf8))

# Convert from CP125
csv SELECT "cp1250 to ascii"	= convert('string', convert('cp1252',		'ascii',	:data:cp1252))
csv SELECT "cp1250 to latin1"	= convert('string', convert('CP1252',		'latin1',	:data:cp1252))
csv SELECT "cp1250 to cp1252"	= convert('string', convert('windows-1252',	'cp1252',	:data:cp1252))
csv SELECT "cp1250 to utf8"	= convert('string', convert('Windows1252',	'utf8',		:data:cp1252))

# Convert from Vanco
csv SELECT "vanco to ascii"	= convert('string', convert('vanco',		'ascii',	:data:vanco))
csv SELECT "vanco to latin1"	= convert('string', convert('Vanco',		'latin1',	:data:vanco))
csv SELECT "vanco to cp1252"	= convert('string', convert('VANCO',		'cp1252',	:data:vanco))
csv SELECT "vanco to utf8"	= convert('string', convert('vAnCo',		'utf8',		:data:vanco))

# check converting from single byte to multiple 
csv SELECT "one byte to multi" = to_hex(convert('cp1252', 'utf8', from_hex('92')))

# convert multiple bytes into single 
csv SELECT "multi to one byte" = to_hex(convert('utf8', 'cp1252', 'вҖҷ'))

# convert a null 
csv SELECT "NULL value" = to_hex(convert('utf8', 'Latin-1', NULL))



