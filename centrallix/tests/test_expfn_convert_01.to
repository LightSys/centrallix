##NAME convert() function - Encodings

# generate a full set of valid bytes for single byte encodings, and a representative sample for multibyte.
# use to/from hex to convert to binary datatype
query DECLARE OBJECT data SCOPE APPLICATION; SELECT :data:utf8 = 'AaBbCc010203,!"¡¢¥ÆÃぁあぃいぅうぇえぉ🨀🨁🨂🨃🨄🨅'
# full hex set: ''
query SELECT :data:ascii	= convert('string', from_hex('0102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f202122232425262728292a2b2c2d2e2f303132333435363738393a3b3c3d3e3f404142434445464748494a4b4c4d4e4f505152535455565758595a5b5c5d5e5f606162636465666768696a6b6c6d6e6f707172737475767778797a7b7c7d7e7f'))
query SELECT :data:latin1	= convert('string', from_hex('202122232425262728292a2b2c2d2e2f303132333435363738393a3b3c3d3e3f404142434445464748494a4b4c4d4e4f505152535455565758595a5b5c5d5e5f606162636465666768696a6b6c6d6e6f707172737475767778797a7b7c7d7ea0a1a2a3a4a5a6a7a8a9aaabacadaeafb0b1b2b3b4b5b6b7b8b9babbbcbdbebf' + 'c0c1c2c3c4c5c6c7c8c9cacbcccdcecfd0d1d2d3d4d5d6d7d8d9dadbdcdddedfe0e1e2e3e4e5e6e7e8e9eaebecedeeeff0f1f2f3f4f5f6f7f8f9fafbfcfdfeff'))
query SELECT :data:cp1252	= convert('string', from_hex('0102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f202122232425262728292a2b2c2d2e2f303132333435363738393a3b3c3d3e3f404142434445464748494a4b4c4d4e4f505152535455565758595a5b5c5d5e5f606162636465666768696a6b6c6d6e6f707172737475767778797a7b7c7d7e7f' + '8082838485868788898a8b8c8e9192939495969798999a9b9c9e9fa0a1a2a3a4a5a6a7a8a9aaabacadaeafb0b1b2b3b4b5b6b7b8b9babbbcbdbebfc0c1c2c3c4c5c6c7c8c9cacbcccdcecfd0d1d2d3d4d5d6d7d8d9dadbdcdddedfe0e1e2e3e4e5e6e7e8e9eaebecedeeeff0f1f2f3f4f5f6f7f8f9fafbfcfdfeff'))
query SELECT :data:vanco	= convert('string', from_hex('c280c282c283c284c285c286c287c289c289c28ac28bc28cc28ec28ec291c292c293c294c295c296c297c298c299c29ac29bc29cc29ec29f')) + :data:ascii + "¡¢£¤¥¦§¨©ª«¬®¯°±²³´µ¶·¸¹º»¼½¾¿ÀÁÂÃÄÅÆÇÈÉÊËÌÍÎÏÐÑÒÓÔÕÖ×ØÙÚÛÜÝÞßàáâãäåæçèéêëìíîïðñòóôõö÷øùúûüýþÿ"

# Convert from ASCII
csv SELECT "ascii to ascii"	= convert(:data:ascii,	'ascii',	'ascii')
csv SELECT "ascii to latin1"	= convert(:data:ascii,	'latin1',	'AsCiI')
csv SELECT "ascii to cp1252"	= convert(:data:ascii,	'cp1252',	'aScIi')
csv SELECT "ascii to utf8"	= convert(:data:ascii,	'utf8',		'ASCII')

# Convert from Latin-1
csv SELECT "latin1 to ascii"	= convert(:data:latin1,	'ascii',	'latin1')
csv SELECT "latin1 to latin1"	= convert(:data:latin1,	'latin1',	'LATIN-1')
csv SELECT "latin1 to cp1252"	= convert(:data:latin1,	'cp1252',	'ISO-8859-1')
csv SELECT "latin1 to utf8"	= convert(:data:latin1,	'utf8',		'ISO/IEC 8859-1')
# test more names 
csv select "latin1 names test" = convert(convert('Test', 'EIC-8859-1', 'iso/iec 8859-1'), 'ISO 8859-1', 'EIC 8859-1')

# Convert from UTF-8
csv SELECT "utf8 to ascii"	= convert(:data:utf8,	'ascii',	'utf8')
csv SELECT "utf8 to latin1"	= convert(:data:utf8,	'latin1',	'UTF-8')
csv SELECT "utf8 to cp1252"	= convert(:data:utf8,	'cp1252',	'Unicode')
csv SELECT "utf8 to utf8"	= convert(:data:utf8,	'utf8',		'uniCode')

# Convert from CP1252
csv SELECT "cp1252 to ascii"	= convert(:data:cp1252,	'ascii',	'cp1252')
csv SELECT "cp1252 to latin1"	= convert(:data:cp1252,	'latin1',	'CP1252')
csv SELECT "cp1252 to cp1252"	= convert(:data:cp1252,	'cp1252',	'windows-1252')
csv SELECT "cp1252 to utf8"	= convert(:data:cp1252,	'utf8',		'Windows1252')

# Convert from Vanco
csv SELECT "vanco to ascii"	= convert(:data:vanco,	'ascii',	'vanco')
csv SELECT "vanco to latin1"	= convert(:data:vanco,	'latin1',	'Vanco')
csv SELECT "vanco to cp1252"	= convert(:data:vanco,	'cp1252',	'VANCO')
csv SELECT "vanco to utf8"	= convert(:data:vanco,	'utf8',		'vAnCo')

# check converting from single byte to multiple 
csv SELECT "one byte to multi" = to_hex(convert(from_hex('92'), 'utf8', 'cp1252'))

# convert multiple bytes into single 
csv SELECT "multi to one byte" = to_hex(convert('’', 'cp1252', 'utf8'))

# convert a null 
csv SELECT "NULL value" = to_hex(convert(NULL, 'Latin-1', 'utf8',))



