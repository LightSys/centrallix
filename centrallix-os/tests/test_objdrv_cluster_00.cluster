$Version=2$
test_objdrv_cluster_00 "system/cluster"
    {
    // Declare parameters.
    algorithm "cluster/parameter" { type = string; }
    k "cluster/parameter" { type = integer; }
    threshold "cluster/parameter" { type = double; }
    sim "cluster/parameter" { type = string; }
    
    // Declare data source.
    source = "/tests/test_objdrv_cluster_00.csv/rows";
    key_attr = "key";
    data_attr = "data";
    
    // A cluster for searching with clustering.
    cluster "cluster/cluster"
	{
	algorithm = runserver(:parameters:algorithm);
	similarity_measure = "cosine";
	num_clusters = runserver(:parameters:k);
	min_improvement = 0.0001;
	max_iterations = 16;
	window_size = 3;
	seed = 1;
	}
    
    search "cluster/search"
	{
	source = cluster;
	similarity_measure = runserver(:parameters:sim);
	threshold = runserver(:parameters:threshold);
	}
    }
